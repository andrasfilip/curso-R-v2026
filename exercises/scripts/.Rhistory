library(rio)
library(tidyverse)
# Load reusable preprocessing functions
source("/Users/Filip/Documents/PhD_2026/r_functions/load_all.R")
options(scipen = 999)
#| label: load-data
# Import raw data from E-Prime
d <- import("../../data/raw_data/1. Lexical Decision Task.csv")
# Convert column names to lowercase
names(d) <- tolower(names(d))
# Preprocessing pipeline
d <- d |>
filter(is.na(bloques) == FALSE) |> # Remove practice trials
dplyr::select(
experimentname,
subject,
age,
handedness,
sex,
list = bloques,
trial_list_order = subtrial,
trial_order = experimental.sample,
ACC = "presentestim.acc[subtrial]",
RT = "presentestim.rt[subtrial]",
stimuli_num = "id[subtrial]",
stimuli = "estim[subtrial]",
word_type = "pal[subtrial]",      # p = word, ps = pseudoword
syl_freq = "sf[subtrial]",        # a = high, b = low
wrd_freq = "wf[subtrial]"         # a = high, b = low, c = pseudoword
) |>
arrange(subject) |>
mutate(
ACC = if_else(ACC == 1, 0, 1),    # Recode: 0 = correct, 1 = error
log_RT = log(RT),
condition = case_when(
wrd_freq == "a" & syl_freq == "a" ~ 1,  # high-high
wrd_freq == "a" & syl_freq == "b" ~ 2,  # high-low
wrd_freq == "b" & syl_freq == "a" ~ 3,  # low-high
wrd_freq == "b" & syl_freq == "b" ~ 4   # low-low
),
# Effect coding: High = +0.5, Low = -0.5
syl_freq.cod = if_else(syl_freq == "a", 0.5, -0.5),
wrd_freq.cod = if_else(wrd_freq == "a", 0.5, -0.5),
bloque.cod = if_else(trial_order <= 80, -0.5, 0.5)
) |>
filter(word_type == "p")  # Keep only words, remove pseudowords
# Standardize subject IDs using reusable function
d$subject <- standardize_subject_ids(as.factor(d$subject), n_subjects = 28)
# Check data structure
cat("Total observations:", nrow(d), "\n")
cat("Subjects:", length(unique(d$subject)), "\n")
cat("Trials per subject:", nrow(d) / 28, "\n")
#| label: sanity-checks
# Check trial distribution by block
xtabs(~ subject + bloque.cod, data = d)
#| label: error-analysis
# Split into correct and error trials
errors_without <- filter(d, ACC == 0)  # Correct responses
errors_with <- filter(d, ACC == 1)     # Errors
# Overall error rate
error_rate <- round(100 - (nrow(errors_without) / nrow(d)) * 100, digits = 2)
cat("Overall error rate:", error_rate, "%\n")
#| label: error-by-condition
cell_trial_count <- 560
# By word × syllable frequency
t_acc_full <- errors_with %>%
group_by(wrd_freq.cod, syl_freq.cod) %>%
summarise(
count = n(),
`error rate [%]` = round((count / cell_trial_count) * 100, 2),
.groups = "drop"
)
knitr::kable(t_acc_full, caption = "Error rates by condition")
#| label: error-by-word-freq
cell_trial_count <- 560 * 2
# By word frequency
t_acc_wf <- errors_with %>%
group_by(wrd_freq.cod) %>%
summarise(
count = n(),
`error rate [%]` = round((count / cell_trial_count) * 100, 2),
.groups = "drop"
) %>%
mutate(word_freq = if_else(wrd_freq.cod == 0.5, "High", "Low"))
knitr::kable(t_acc_wf, caption = "Error rates by word frequency")
#| label: error-by-syl-freq
# By syllable frequency
t_acc_sf <- errors_with %>%
group_by(syl_freq.cod) %>%
summarise(
count = n(),
`error rate [%]` = round((count / cell_trial_count) * 100, 2),
.groups = "drop"
) %>%
mutate(syl_freq = if_else(syl_freq.cod == 0.5, "High", "Low"))
knitr::kable(t_acc_sf, caption = "Error rates by syllable frequency")
#| label: participant-check
x <- 80  # Total trials per participant
participant_summary <- check_participants(
df_errors_with = errors_with,
df_outliers_with = outliers_with,
df_outliers_without = outliers_without,
trials_per_subject = x
)
?select
