datos_ancho <- tibble::tibble(
paciente = 1:3,
dia_1    = c(10, 8, 12),
dia_2    = c(7, 6, 9),
dia_3    = c(5, 4, 7)
)
datos_largo <- datos_ancho |>
pivot_longer(
cols      = starts_with("dia_"),
names_to  = "día",
values_to = "puntuacion"
)
