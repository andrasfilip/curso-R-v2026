library(knitr)
# resumen ancho: una fila por grupo, columnas pre / post / mejora
trial |>
group_by(group) |>
summarise(
pre     = round(mean(anxiety_pre), 1),
post    = round(mean(anxiety_post), 1),
.groups = "drop"
) |>
mutate(mejora = pre - post) |>
arrange(desc(mejora)) |>
kable(
col.names = c("Grupo", "Ansiedad pre", "Ansiedad post", "Mejora"),
caption   = "Media de ansiedad por grupo de tratamiento"
)
