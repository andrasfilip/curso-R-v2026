# ------------------------------------------------------------
# EJERCICIO: Crear proyecto y cargar datos
# ------------------------------------------------------------
# Tiempo: 5 minutos
#
# 1. Comprueba tu directorio de trabajo
getwd()
# 2. Carga el tidyverse
library(tidyverse)
# 3. Carga el dataset del ensayo clinico
data_trial <- readr::read_csv("data/data_clinical_trial.csv")
# 3. Carga el dataset del ensayo clinico
data_trial <- readr::read_csv("data/data_clinical_trial.csv")
# 4. Explora los datos
glimpse(data_trial)
head(data_trial)
table(data_trial$group)
# 5. Carga los datos de clinicas
sites <- readr::read_csv("data/data_sites.csv")
# 3. Carga el dataset del ensayo clinico
data_trial <- readr::read_csv("data/raw_data/data_clinical_trial.csv")
# 4. Explora los datos
glimpse(data_trial)
head(data_trial)
table(data_trial$group)
# 5. Carga los datos de clinicas
sites <- readr::read_csv("data/raw_data/data_sites.csv")
glimpse(sites)
# 6. Usa View() en la consola para ver los datos visualmente
View(data_trial)
View(sites)
# ------------------------------------------------------------
# EJERCICIO 2: Crear proyecto y cargar datos
# ------------------------------------------------------------
# Tiempo: 5 minutos
#
# 1. Comprueba tu directorio de trabajo
getwd()
# dplyr::select() --- elegir columnas
data_trial |>
dplyr::select(patient_id, group, sex, anxiety_pre, anxiety_post)
# select() --- eliminar columnas
data_trial |>
dplyr::select(-site_id, -wellbeing_pre)
# select() --- funciones auxiliares
data_trial |>
dplyr::select(patient_id, group, contains("anxiety"))
# dplyr::rename() --- renombrar columnas (nuevo = viejo)
data_trial |>
dplyr::rename(grupo = group, edad = age) |>
dplyr::select(patient_id, grupo, edad, anxiety_pre)
# dplyr::relocate() --- reordenar columnas (.after)
data_trial |>
dplyr::relocate(anxiety_post, .after = patient_id)
# dplyr::relocate() --- argumento .before
data_trial |>
dplyr::relocate(wellbeing_pre, .before = patient_id)
# dplyr::filter() --- elegir filas
data_trial |>
dplyr::filter(group == "CBT")
# dplyr::filter() --- elegir filas
data_trial |>
dplyr::filter(group == "CBT")
# filter() --- multiples condiciones (AND)
data_trial |>
dplyr::filter(sex == "female", age > 45, group == "CBT")
# filter() --- condiciones OR
data_trial |>
dplyr::filter(group == "CBT" | group == "pharmacological")
# equivalente usando %in%
data_trial |>
dplyr::filter(group %in% c("CBT", "pharmacological"))
# combinar select() y filter() con el pipe
data_trial |>
dplyr::filter(group == "CBT") |>
dplyr::select(patient_id, sex, age, anxiety_pre, anxiety_post)
# combinar select() y filter() con el pipe
data_trial |>
dplyr::filter(group == "CBT") |>
dplyr::select(patient_id, sex, age, anxiety_pre, anxiety_post)
# equivalente usando %in%
data_trial |>
dplyr::filter(group %in% c("CBT", "pharmacological"))
# filter() --- condiciones OR
data_trial |>
dplyr::filter(group == "CBT" | group == "pharmacological")
# filter() --- multiples condiciones (AND)
data_trial |>
dplyr::filter(sex == "female", age > 45, group == "CBT")
# dplyr::filter() --- elegir filas
data_trial |>
dplyr::filter(group == "CBT")
# mutate() --- crear nuevas columnas
data_trial |>
dplyr::mutate(mejora = anxiety_pre - anxiety_post) |>
dplyr::select(patient_id, group, anxiety_pre, anxiety_post, mejora)
# if_else() --- dos categorias
data_trial |>
dplyr::mutate(
edad_grupo = if_else(age >= 45, "senior", "junior")
) |>
dplyr::select(patient_id, age, edad_grupo)
# case_when() --- multiples categorias
data_trial |>
dplyr::mutate(
severidad = case_when(
anxiety_pre <= 4  ~ "minima",
anxiety_pre <= 9  ~ "leve",
anxiety_pre <= 14 ~ "moderada",
TRUE              ~ "severa"
)
) |>
dplyr::select(patient_id, anxiety_pre, severidad) |>
head(10)
# equivalente usando %in%
data_trial |>
dplyr::filter(group %in% c("CBT", "pharmacological"))
# filter() --- condiciones OR
data_trial |>
dplyr::filter(group == "CBT" | group == "pharmacological")
# equivalente usando %in%
data_trial |>
dplyr::filter(group %in% c("CBT", "pharmacological"))
# filter() --- condiciones OR
data_trial |>
dplyr::filter(group == "CBT" | group == "pharmacological")
# equivalente usando %in%
data_trial |>
dplyr::filter(group %in% c("CBT", "pharmacological"))
# dplyr::select() --- elegir columnas
datos_seleccionados <- data_trial |>
dplyr::select(patient_id, group, sex, anxiety_pre, anxiety_post)
# ------------------------------------------------------------
# EJERCICIO 2: Crear proyecto y cargar datos
# ------------------------------------------------------------
# Tiempo: 5 minutos
#
# 1. Comprueba tu directorio de trabajo
getwd()
# 2. Carga el tidyverse
library(tidyverse)
# 3. Carga el dataset del ensayo clinico
data_trial <- readr::read_csv("data/raw_data/data_clinical_trial.csv")
# 4. Explora los datos
glimpse(data_trial)
head(data_trial)
table(data_trial$group)
# 5. Carga los datos de clinicas
sites <- readr::read_csv("data/raw_data/data_sites.csv")
glimpse(sites)
# 6. Usa View() en la consola para ver los datos visualmente
View(data_trial)
View(sites)
