# dplyr::select() --- elegir columnas
datos_seleccionados <- data_trial |>
dplyr::select(patient_id, group, sex, anxiety_pre, anxiety_post)
datos_seleccionados
View(datos_seleccionados)
# select() --- eliminar columnas
datos_reducidos <- data_trial |>
dplyr::select(-site_id, -wellbeing_pre)
datos_reducidos
View(datos_reducidos)
# select() --- funciones auxiliares
datos_anxiety <- data_trial |>
dplyr::select(patient_id, group, contains("anxiety"))
datos_anxiety
View(datos_anxiety)
# dplyr::rename() --- renombrar columnas (nuevo = viejo)
datos_renombrados <- data_trial |>
dplyr::rename(grupo = group, edad = age) |>
dplyr::select(patient_id, grupo, edad, anxiety_pre)
datos_renombrados
# dplyr::relocate() --- reordenar columnas (.after)
datos_reordenados <- data_trial |>
dplyr::relocate(anxiety_post, .after = patient_id)
datos_reordenados
# dplyr::relocate() --- argumento .before
datos_reordenados2 <- data_trial |>
dplyr::relocate(wellbeing_pre, .before = patient_id)
datos_reordenados2
