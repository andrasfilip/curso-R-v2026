library(tidyverse)
options(scipen = 999)
salary <- read_csv("data/raw_data/data_salary.csv")
library(readr)
data_salary <- read_csv("~/Documents/MdM_2025/__Cursos/_Curso2 - R/intro_to_R/homework/day2_salary/data/raw_data/data_salary.csv")
View(data_salary)
salary <- data_salary
# estructura del dataset
glimpse(salary)
# frecuencias de las variables categoricas
table(salary$gender)
table(salary$statistic)
table(salary$year)
# solo la media (excluye cuartiles), solo male/female, anos 2008-2017
salary_clean <- salary |>
filter(
statistic == "mean",
gender != "both",
year >= 2008,
year <= 2017
)
View(data_salary)
salary_clean
salary_by_year <- salary_clean |>
group_by(year, gender) |>
summarise(
mean_income = mean(gross_income_euros, na.rm = TRUE),
.groups = "drop"
)
salary_by_year
salary_wide <- salary_by_year |>
pivot_wider(
names_from  = gender,
values_from = mean_income
)
salary_wide
salary_wide |>
mutate(gap = male - female) |>
arrange(desc(gap))
View(data_salary)
View(salary_clean)
# brecha por CCAA en el ano 2017
gap_ccaa_2017 <- salary_clean |>
filter(year == 2017) |>
group_by(state, gender) |>
summarise(
mean_income = mean(gross_income_euros, na.rm = TRUE),
.groups = "drop"
) |>
pivot_wider(names_from = gender, values_from = mean_income) |>
mutate(gap = male - female) |>
arrange(desc(gap))
gap_ccaa_2017
# CCAA con mayor brecha
gap_ccaa_2017 |> slice_head(n = 1)
# CCAA con menor brecha
gap_ccaa_2017 |> slice_tail(n = 1)
